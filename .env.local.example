# Admin editor at /admin/27348 — copy this file to .env.local and fill in real values.

# Password required to unlock the admin editor.
# Pick something strong. Anyone with this value can edit the public site content.
ADMIN_PASSWORD=changeme

# HMAC secret used to sign the admin session cookie.
# Generate a random 32+ char string. NEVER reuse the password here.
# Example: openssl rand -hex 32
ADMIN_SECRET=please-replace-with-a-long-random-string
